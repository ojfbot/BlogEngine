{
  "name": "@blogengine/agent-core",
  "version": "0.1.0",
  "description": "Core types, schemas, and utilities for BlogEngine",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": "./dist/index.js",
    "./models/*": "./dist/models/*.js",
    "./utils/*": "./dist/utils/*.js",
    "./types/*": "./dist/types/*.js"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "type-check": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "zod": "^3.23.8",
    "dotenv": "^16.4.7",
    "pino": "^9.5.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "pino-pretty": "^13.0.0",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3"
  },
  "publishConfig": {
    "access": "restricted"
  }
}
