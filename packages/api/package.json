{
  "name": "@blogengine/api",
  "version": "0.1.0",
  "description": "Express.js REST API for BlogEngine",
  "type": "module",
  "main": "./dist/server.js",
  "types": "./dist/server.d.ts",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "start": "node dist/server.js",
    "build": "tsc",
    "type-check": "tsc --noEmit",
    "test": "vitest run",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@blogengine/agent-core": "workspace:*",
    "@blogengine/agent-graph": "workspace:*",
    "@blogengine/notion-integration": "workspace:*",
    "@blogengine/publisher": "workspace:*",
    "@blogengine/rag-service": "workspace:*",
    "express": "^4.21.2",
    "cors": "^2.8.5",
    "helmet": "^8.0.0",
    "express-rate-limit": "^7.4.1",
    "jsonwebtoken": "^9.0.2",
    "multer": "^1.4.5-lts.1",
    "pino": "^9.5.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "pino-pretty": "^13.0.0",
    "@types/express": "^5.0.0",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/multer": "^1.4.12",
    "@types/node": "^22.10.2",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "vitest": "catalog:"
  },
  "publishConfig": {
    "access": "restricted"
  }
}
